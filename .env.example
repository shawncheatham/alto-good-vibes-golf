# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Buy Me a Coffee Webhook
# Get this from BMC dashboard > Webhooks when configuring the webhook
BMC_WEBHOOK_SECRET=your_bmc_webhook_secret_here
